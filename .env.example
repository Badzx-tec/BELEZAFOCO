NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/belezafoco?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/belezafoco?schema=public
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
CORS_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3333
PUBLIC_URL=http://localhost:5173
PUBLIC_DEMO_ENABLED=true
LOG_LEVEL=debug
SUPERADMIN_EMAIL=admin@belezafoco.com

# WhatsApp providers
WHATSAPP_PROVIDER=mock
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_APP_SECRET=

# Email fallback (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_ORIGINS=http://localhost:5173

# Mercado Pago PIX
MERCADO_PAGO_ENABLED=false
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend
VITE_API_URL=http://localhost:3333

# Seed
SEED_ADMIN_EMAIL=admin@belezafoco.local
SEED_ADMIN_PASSWORD=12345678
SEED_WORKSPACE_NAME=Studio Beleza Foco
SEED_WORKSPACE_SLUG=demo-beleza
