NODE_ENV=development
PORT=3333
LOG_LEVEL=info

# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/belezafoco
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/belezafoco
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change_me_access_secret_please
JWT_REFRESH_SECRET=change_me_refresh_secret_please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# URLs
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
API_BASE_URL=http://localhost:3333
PUBLIC_URL=http://localhost:5173
APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3333
PUBLIC_DEMO_ENABLED=true

# Docker / Compose overrides
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/belezafoco
DOCKER_REDIS_URL=redis://redis:6379
DOCKER_SMTP_HOST=mailhog
DOCKER_SMTP_PORT=1025
DOCKER_PUBLIC_URL=http://localhost
DOCKER_APP_URL=http://localhost
DOCKER_CORS_ORIGIN=http://localhost
DOCKER_VITE_API_URL=/api
DOCKER_API_UPSTREAM=api:3333
CADDY_SITE_ADDRESS=:80
WEB_HTTP_PORT=80
WEB_HTTPS_PORT=443

# Ops
SUPERADMIN_EMAIL=admin@belezafoco.com

# Sentry backend
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1

# Sentry frontend
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=1

# Sentry sourcemaps / releases
SENTRY_AUTH_TOKEN=
SENTRY_ORG=thark-s4
SENTRY_PROJECT_WEB=belezafoco-web
WORKER_REMINDERS_INTERVAL_SECONDS=60
WORKER_RECONCILE_INTERVAL_SECONDS=300
WORKER_CLEANUP_INTERVAL_SECONDS=900

# WhatsApp providers
WHATSAPP_PROVIDER=mock
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=

# Email fallback
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Mercado Pago PIX
MERCADO_PAGO_ENABLED=false
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=local_webhook_secret

# Seed
SEED_ADMIN_EMAIL=admin@belezafoco.local
SEED_ADMIN_PASSWORD=12345678
