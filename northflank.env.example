# API e Worker
NODE_ENV=production
PORT=3333
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/belezafoco
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/belezafoco
REDIS_URL=redis://default:PASSWORD@HOST:6379
JWT_ACCESS_SECRET=change_me_access_secret_please
JWT_REFRESH_SECRET=change_me_refresh_secret_please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
CORS_ORIGIN=https://belezafoco-web.example.northflank.app
API_BASE_URL=https://belezafoco-api.example.northflank.app
PUBLIC_URL=https://belezafoco-web.example.northflank.app
APP_URL=https://belezafoco-web.example.northflank.app
PUBLIC_DEMO_ENABLED=true
LOG_LEVEL=info
SUPERADMIN_EMAIL=admin@belezafoco.com
SENTRY_DSN=
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.2
WHATSAPP_PROVIDER=mock
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_API_VERIFY_TOKEN=change_me_whatsapp_verify_token
WHATSAPP_CLOUD_API_APP_SECRET=change_me_whatsapp_app_secret
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
GOOGLE_CLIENT_ID=
GOOGLE_ALLOWED_ORIGINS=https://belezafoco-web.example.northflank.app,https://p03--belezafoco-api--fdzfclqyqq99.code.run
MERCADO_PAGO_ENABLED=false
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=change_me_mp_webhook_secret
WORKER_REMINDERS_INTERVAL_SECONDS=60
WORKER_RECONCILE_INTERVAL_SECONDS=300
WORKER_CLEANUP_INTERVAL_SECONDS=900

# Build args do Web
VITE_API_URL=https://belezafoco-api.example.northflank.app
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=staging
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_AUTH_TOKEN=
SENTRY_ORG=thark-s4
SENTRY_PROJECT_WEB=belezafoco-web
SENTRY_RELEASE=

# Runtime do Web
API_UPSTREAM=api:3333
CADDY_SITE_ADDRESS=:80

# Seed / demo comercial
SEED_WORKSPACE_NAME=Studio Beleza Foco
SEED_WORKSPACE_SLUG=demo-beleza
