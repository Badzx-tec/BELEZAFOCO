{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@belezafoco/ui": ["packages/ui/src"],
      "@belezafoco/ui/*": ["packages/ui/src/*"],
      "@belezafoco/types": ["packages/types/src"],
      "@belezafoco/types/*": ["packages/types/src/*"],
      "@belezafoco/database": ["packages/database/src"],
      "@belezafoco/database/*": ["packages/database/src/*"],
      "@belezafoco/sdk": ["packages/sdk/src"],
      "@belezafoco/sdk/*": ["packages/sdk/src/*"]
    }
  }
}
