{
  "name": "belezafoco",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.1",
  "devDependencies": {
    "@types/node": "^24.3.0"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev": "corepack pnpm --parallel --filter @belezafoco/api --filter @belezafoco/web dev",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "prisma:migrate": "corepack pnpm --filter @belezafoco/api prisma:migrate",
    "prisma:generate": "corepack pnpm --filter @belezafoco/api prisma:generate",
    "seed": "corepack pnpm --filter @belezafoco/api seed"
  }
}
