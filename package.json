{
  "name": "belezafoco",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @belezafoco/api --filter @belezafoco/web dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prisma:migrate": "pnpm --filter @belezafoco/api prisma:migrate",
    "prisma:generate": "pnpm --filter @belezafoco/api prisma:generate",
    "seed": "pnpm --filter @belezafoco/api seed"
  }
}
