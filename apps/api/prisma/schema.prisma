generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  manager
  staff
  receptionist
}

enum PriceType {
  fixed
  starts_at
  varies
  free
}

enum DepositType {
  percent
  fixed
}

enum AppointmentStatus {
  requested
  pending_payment
  confirmed
  cancelled
  rescheduled
  done
  no_show
  late_cancel
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum SubscriptionPlan {
  trial
  basic
  pro
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id                     String @id @default(cuid())
  name                   String
  slug                   String @unique
  timezone               String @default("America/Sao_Paulo")
  address                String?
  minAdvanceMinutes      Int @default(120)
  maxAdvanceDays         Int @default(30)
  freeCancelHours        Int @default(24)
  lateCancelFeePercent   Int @default(0)
  noShowFeePercent       Int @default(0)
  createdAt              DateTime @default(now())
  memberships            Membership[]
  services               Service[]
  staffMembers           StaffMember[]
  resources              Resource[]
  appointments           Appointment[]
  clients                Client[]
  templates              MessageTemplate[]
  waitlistEntries        WaitlistEntry[]
  subscription           WorkspaceSubscription?
  auditLogs              AuditLog[]
  businessHours          BusinessHour[]
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@unique([userId, workspaceId])
}

model BusinessHour {
  id          String @id @default(cuid())
  workspaceId String
  weekday     Int
  startTime   String
  endTime     String
  workspace   Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
}

model Service {
  id                  String @id @default(cuid())
  workspaceId         String
  name                String
  category            String
  durationMinutes     Int
  bufferBeforeMinutes Int @default(0)
  bufferAfterMinutes  Int @default(0)
  priceType           PriceType
  priceValue          Int?
  depositEnabled      Boolean @default(false)
  depositType         DepositType?
  depositValue        Int?
  requiredResourceId  String?
  active              Boolean @default(true)
  workspace           Workspace @relation(fields: [workspaceId], references:[id], onDelete: Cascade)
  requiredResource    Resource? @relation("RequiredResource", fields:[requiredResourceId], references:[id])
  staffServices       StaffService[]
  appointments        Appointment[]
}

model StaffMember {
  id           String @id @default(cuid())
  workspaceId  String
  name         String
  contact      String?
  workspace    Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  availabilities StaffAvailability[]
  exceptions   StaffException[]
  staffServices StaffService[]
  appointments Appointment[]
}

model StaffService {
  staffMemberId String
  serviceId     String
  staffMember   StaffMember @relation(fields:[staffMemberId], references:[id], onDelete: Cascade)
  service       Service @relation(fields:[serviceId], references:[id], onDelete: Cascade)
  @@id([staffMemberId, serviceId])
}

model StaffAvailability {
  id            String @id @default(cuid())
  staffMemberId String
  weekday       Int
  startTime     String
  endTime       String
  staffMember   StaffMember @relation(fields:[staffMemberId], references:[id], onDelete: Cascade)
}

model StaffException {
  id            String @id @default(cuid())
  staffMemberId String
  startAt       DateTime
  endAt         DateTime
  reason        String?
  staffMember   StaffMember @relation(fields:[staffMemberId], references:[id], onDelete: Cascade)
}

model Resource {
  id            String @id @default(cuid())
  workspaceId   String
  name          String
  type          String
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  services      Service[] @relation("RequiredResource")
  appointments  Appointment[]
}

model Client {
  id               String @id @default(cuid())
  workspaceId      String
  name             String
  whatsapp         String
  email            String?
  notes            String?
  whatsappOptInAt  DateTime?
  whatsappOptInIp  String?
  whatsappOptInMethod String?
  workspace        Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  appointments     Appointment[]
  waitlistEntries  WaitlistEntry[]
  @@unique([workspaceId, whatsapp])
}

model Appointment {
  id            String @id @default(cuid())
  workspaceId   String
  serviceId     String
  staffMemberId String
  resourceId    String?
  clientId      String
  status        AppointmentStatus
  startAt       DateTime
  endAt         DateTime
  depositAmount Int?
  depositProvider String?
  depositStatus PaymentStatus?
  cancelToken   String? @unique
  createdAt     DateTime @default(now())
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  service       Service @relation(fields:[serviceId], references:[id])
  staffMember   StaffMember @relation(fields:[staffMemberId], references:[id])
  resource      Resource? @relation(fields:[resourceId], references:[id])
  client        Client @relation(fields:[clientId], references:[id])
  payments      Payment[]
  reminders     ReminderLog[]
  @@unique([staffMemberId, startAt])
  @@unique([resourceId, startAt])
}

model Payment {
  id            String @id @default(cuid())
  appointmentId String
  provider      String
  externalId    String?
  amount        Int
  status        PaymentStatus
  qrCode        String?
  pixCopyPaste  String?
  createdAt     DateTime @default(now())
  appointment   Appointment @relation(fields:[appointmentId], references:[id], onDelete: Cascade)
}

model WaitlistEntry {
  id            String @id @default(cuid())
  workspaceId   String
  clientId      String
  serviceId     String
  staffMemberId String?
  desiredDate   DateTime
  token         String @unique
  tokenExpiresAt DateTime
  active        Boolean @default(true)
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  client        Client @relation(fields:[clientId], references:[id], onDelete: Cascade)
  service       Service @relation(fields:[serviceId], references:[id])
}

model MessageTemplate {
  id            String @id @default(cuid())
  workspaceId   String
  type          String
  templateName  String
  language      String @default("pt_BR")
  body          String
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
  @@unique([workspaceId, type])
}

model ReminderLog {
  id            String @id @default(cuid())
  appointmentId String
  type          String
  provider      String
  status        String
  response      String?
  sentAt        DateTime @default(now())
  appointment   Appointment @relation(fields:[appointmentId], references:[id], onDelete: Cascade)
  @@unique([appointmentId, type])
}

model WorkspaceSubscription {
  id            String @id @default(cuid())
  workspaceId   String @unique
  plan          SubscriptionPlan @default(trial)
  paidUntil     DateTime
  appointmentsThisMonth Int @default(0)
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
}

model AuditLog {
  id            String @id @default(cuid())
  workspaceId   String
  actorUserId   String?
  action        String
  entityType    String
  entityId      String
  payload       String
  createdAt     DateTime @default(now())
  workspace     Workspace @relation(fields:[workspaceId], references:[id], onDelete: Cascade)
}
