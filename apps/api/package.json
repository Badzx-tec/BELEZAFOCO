{
  "name": "@belezafoco/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/server.ts",
    "worker:dev": "tsx watch --import ./src/instrument.ts src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps --import ./dist/src/instrument.js dist/src/server.js",
    "worker:start": "node --enable-source-maps --import ./dist/src/instrument.js dist/src/worker.js",
    "test": "vitest run",
    "lint": "echo 'no lint'",
    "prisma:generate": "node scripts/prisma-with-env.mjs generate --schema prisma/schema.prisma",
    "prisma:migrate": "node scripts/prisma-with-env.mjs migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "node scripts/prisma-with-env.mjs migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@belezafoco/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^5.20.0",
    "@sentry/node": "10.42.0",
    "argon2": "^0.41.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
